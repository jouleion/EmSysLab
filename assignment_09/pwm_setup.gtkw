[gtkwave]
version 3

[dumpfile]
signals.vcd

[signals]
begin
/PWM_Motordriver_tb/enable
/PWM_Motordriver_tb/dir
/PWM_Motordriver_tb/brake
/PWM_Motordriver_tb/speed
/PWM_Motordriver_tb/dut/PITCH_PWM_VAL
/PWM_Motordriver_tb/dut/PITCH_DIRA
/PWM_Motordriver_tb/dut/PITCH_DIRB
end

[options]
timeformat %0t

# Saved setup: add more signals in the [signals] block if needed
